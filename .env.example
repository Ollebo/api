# Local api config. Copy to `.env` (git-ignored) for docker-compose to load it:
#     cp .env.example .env
# The api needs NO Keycloak secret — token verification uses the public JWKS
# endpoint — so only the KC_* connection info below is required (same vars dw uses).

# --- Keycloak (mirrors dw's KC_* config) ---
# The api derives the JWKS URL: <proto>://<host>[:<port>]/realms/<realm>/protocol/openid-connect/certs
KC_HOST=auth.ollebo.com
KC_PORT=443
KC_PROTOCOL=https
KC_REALM=master
# Optional explicit overrides (take precedence over KC_* if set):
# JWT_JWKS_URL=
# JWT_ISSUER=
# JWT_AUDIENCE=

# --- Datastores (match docker-compose defaults) ---
NATS=nats://nats:4222
POSTGRES_DB=ollebo
POSTGRES_HOST=postgres
POSTGRES_USER=ollebo
POSTGRES_PASSWORD=ollebo
REDIS_HOST=redis
REDIS_PORT=6379
API_KEY=dev-key
